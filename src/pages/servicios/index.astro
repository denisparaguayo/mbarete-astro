---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../data/siteConfig';
import { services } from '../../data/services';
---

<BaseLayout
	title="Servicios de Mbarete Digital"
	description="Conoce todos los servicios de Mbarete Digital: web, SEO local, redes, mantenimiento y mas."
	canonical={`${siteConfig.url}/servicios/`}
	navbarSolid={true}
	breadcrumbs={[
		{ name: 'Inicio', url: '/' },
		{ name: 'Servicios', url: '/servicios/' },
	]}>
	<section class="section section--white services-index" aria-labelledby="services-title">
		<div class="container">
			<div class="services-index__hero fade-up">
				<h1 class="section__title" id="services-title">Servicios</h1>
				<p class="section__subtitle">
					Este es el indice de servicios. Entra a cada pagina para ver detalles y alcance.
				</p>
			</div>

			<div class="services-index__grid">
				{
					services.map((service, index) => (
						<article class="services-index__card fade-up" style={`--delay:${index % 6}`}>
							<div class="services-index__card-inner">
								<div class="services-index__icon-wrap" aria-hidden="true">
									<span class="services-index__icon">{service.icon}</span>
								</div>
								<h2 class="services-index__name">
									<span class="services-index__counter">{String(index + 1).padStart(2, '0')}</span>
									{service.name}
								</h2>
								<p class="services-index__summary">{service.summary}</p>
								<p class="services-index__price">{service.price}</p>
								<a href={`/servicios/${service.slug}/`} class="services-index__link">
									Ver detalle
								</a>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.services-index__hero {
		margin-bottom: 2rem;
	}

	.services-index__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.35rem;
	}

	.services-index__card {
		position: relative;
		padding-top: 3.1rem;
	}

	.services-index__card-inner {
		position: relative;
		background: var(--blanco);
		border-radius: var(--radius-lg);
		border: 1px solid var(--gris-medio);
		padding: 2.1rem 1.2rem 1.2rem;
		box-shadow: 0 14px 36px rgba(10, 22, 40, 0.08);
		transition:
			transform var(--transition-slow),
			box-shadow var(--transition-slow),
			border-color var(--transition);
	}

	.services-index__card-inner::after {
		content: '';
		position: absolute;
		top: 1rem;
		right: 1rem;
		width: 44px;
		height: 44px;
		border-top: 2px solid rgba(26, 58, 107, 0.18);
		border-right: 2px solid rgba(26, 58, 107, 0.18);
		border-radius: 0 12px 0 0;
		transition:
			width var(--transition),
			height var(--transition),
			border-color var(--transition);
	}

	.services-index__card:hover .services-index__card-inner {
		transform: translateY(-6px);
		box-shadow: 0 18px 42px rgba(10, 22, 40, 0.14);
		border-color: rgba(5, 150, 105, 0.35);
	}

	.services-index__card:hover .services-index__card-inner::after {
		width: 68px;
		height: 68px;
		border-color: rgba(5, 150, 105, 0.45);
	}

	.services-index__icon-wrap {
		position: absolute;
		top: -1.9rem;
		left: 50%;
		transform: translateX(-50%);
		width: 76px;
		height: 76px;
		border-radius: 999px;
		background: linear-gradient(160deg, #f8fffc 0%, #dcfce7 100%);
		border: 2px solid rgba(5, 150, 105, 0.24);
		box-shadow: 0 10px 24px rgba(5, 150, 105, 0.24);
		display: grid;
		place-items: center;
	}

	.services-index__icon {
		font-size: 1.85rem;
		line-height: 1;
	}

	.services-index__name {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		font-family: var(--font-titulo);
		font-size: 1.2rem;
		line-height: 1.35;
		color: var(--azul-oscuro);
		margin-top: 1rem;
		margin-bottom: 0.8rem;
	}

	.services-index__counter {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 2rem;
		height: 2rem;
		padding: 0 0.5rem;
		border-radius: var(--radius-pill);
		font-size: 0.84rem;
		font-weight: 800;
		font-family: var(--font-cuerpo);
		color: var(--azul-medio);
		background: rgba(26, 58, 107, 0.1);
	}

	.services-index__summary {
		font-size: 0.94rem;
		color: var(--texto);
		line-height: 1.62;
	}

	.services-index__price {
		margin-top: 0.95rem;
		font-weight: 800;
		color: var(--verde);
	}

	.services-index__link {
		display: inline-flex;
		margin-top: 0.85rem;
		font-weight: 700;
		color: var(--azul-medio);
		position: relative;
	}

	.services-index__link::after {
		content: '';
		width: 0;
		height: 2px;
		position: absolute;
		left: 0;
		bottom: -2px;
		background: var(--verde);
		transition: width var(--transition);
	}

	.services-index__link:hover {
		color: var(--verde);
	}

	.services-index__link:hover::after {
		width: 100%;
	}

	@media (min-width: 768px) {
		.services-index__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1080px) {
		.services-index__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>
