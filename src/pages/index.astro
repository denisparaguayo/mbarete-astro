---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig, getWhatsAppUrl } from "../data/siteConfig";
import {
  getGsAmount,
  getServiceBySlugOrThrow,
  getServicePlanBySlugOrThrow,
} from "../data/services";
import Rubros from "../components/sections/Rubros.astro";
import Serviadicional from "../components/sections/Serviadicional.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import WhatsAppFloat from "../components/ui/WhatsAppFloat.astro";

const creacionWebService = getServiceBySlugOrThrow("creacion-paginas-web");
const seoLocalService = getServiceBySlugOrThrow("seo-local-google-maps");
const planBasico = getServicePlanBySlugOrThrow("basico");
const planEstandar = getServicePlanBySlugOrThrow("estandar");
const planPro = getServicePlanBySlugOrThrow("pro");

const creacionWebPrice = creacionWebService.price;
const seoLocalPrice = seoLocalService.price;
const creacionWebPriceInline = creacionWebPrice.replace(/^Desde/i, "desde");
const basicPlanAmount = getGsAmount(planBasico.price);
const standardPlanAmount = getGsAmount(planEstandar.price);
const proPlanAmount = getGsAmount(planPro.price);

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "¿Cuánto tarda en estar lista mi página?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "El Plan Básico se entrega en 1 a 2 días hábiles desde que recibimos tus datos y el pago. El Plan Estándar tarda 4 a 8 días y el Pro de 7 a 15 días. Son plazos reales, no promesas vacías.",
      },
    },
    {
      "@type": "Question",
      name: "¿Necesito saber algo de tecnología para tener mi página web?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No necesitás saber nada. Vos nos mandás el nombre de tu negocio, los servicios que ofrecés, tu número de WhatsApp y algunas fotos. Nosotros hacemos todo lo demás. Si no tenés fotos, usamos imágenes profesionales gratis.",
      },
    },
    {
      "@type": "Question",
      name: "¿Qué pasa si después quiero cambiar algo en la página?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Todos los planes incluyen cambios por mes: 1 en Básico, 3 en Estándar, ilimitados en Pro. Para cambios urgentes o extras, los cotizamos aparte. Siempre podés escribirnos por WhatsApp.",
      },
    },
    {
      "@type": "Question",
      name: "¿La página va a aparecer en Google?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `Sí. Cada página que entregamos viene con SEO básico configurado para que Google la encuentre. Si querés aparecer en los primeros resultados cuando alguien busca tu rubro en tu ciudad, tenemos el servicio de SEO local por ${seoLocalPrice}.`,
      },
    },
    {
      "@type": "Question",
      name: "¿Qué necesito para empezar?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Solo tres cosas: el nombre y datos de tu negocio, tu número de WhatsApp y el pago del plan elegido. Con eso ya arrancamos. El formulario de datos te lo mandamos por WhatsApp y lo completás desde el celular en 5 minutos.",
      },
    },
  ],
};
---

<BaseLayout
  title="Diseño Web en Paraguay"
  description={`Diseño web en Paraguay ${creacionWebPriceInline}. Creamos páginas web profesionales para negocios en Asunción y todo el país. SEO, WhatsApp y entrega en 1-2 días.`}
  canonical={siteConfig.url}
  schema={faqSchema}
>
  <header
    class="hero"
    id="inicio"
    role="banner"
    aria-label="Presentación principal"
  >
    <div class="hero__bg-pattern" aria-hidden="true"></div>
    <div class="container">
      <div class="hero__badge fade-up">
        <span class="badge badge--py">🇵🇾 Agencia 100% paraguaya</span>
        <span class="badge badge--status" id="status-badge">
          <span class="status-dot" id="status-dot" aria-hidden="true"></span>
          <span id="status-text">Abierto ahora</span>
        </span>
      </div>

      <h1 class="hero__title fade-up">
        Diseño web en Paraguay<br />
        <span class="hero__title-accent">que genera clientes</span>
      </h1>

      <p class="hero__desc fade-up">
        Creamos páginas web profesionales para negocios en Asunción y todo
        Paraguay. Diseño web con SEO incluido, botón WhatsApp y entrega en 1 a 2
        días {creacionWebPriceInline}.
      </p>

      <div class="hero__ctas fade-up">
        <a
          href={getWhatsAppUrl(
            "Hola Mbarete Digital! Quiero consultar sobre una página web para mi negocio 👋",
          )}
          class="btn btn--primary btn--lg"
          id="hero-wa"
          target="_blank"
          rel="noopener noreferrer">Consultá por WhatsApp</a
        >
        <a href="#precios" class="btn btn--outline btn--lg"
          >Ver planes y precios</a
        >
      </div>

      <div class="hero__stats fade-up">
        <div class="stat-card">
          <span class="stat-card__number" data-target="120" data-suffix="+"
            >0</span
          >
          <span class="stat-card__label">negocios atendidos</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__number" data-text="1-2 días">1-2 días</span>
          <span class="stat-card__label">entrega plan básico</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__number" data-text="5.0★">5.0★</span>
          <span class="stat-card__label">calificación Google</span>
        </div>
      </div>
    </div>
  </header>

  <section
    class="section section--white"
    id="servicios"
    aria-labelledby="h2-porque"
  >
    <div class="container">
      <h2 class="section__title fade-up" id="h2-porque">
        ¿Por qué elegir Mbarete Digital?
      </h2>
      <p class="section__subtitle fade-up">
        Más de 120 negocios en Paraguay ya confían en nosotros.
      </p>

      <div class="features-grid">
        <article class="feature-card fade-up" style="--delay:0">
          <div class="feature-card__icon" aria-hidden="true">⚡</div>
          <h3 class="feature-card__title">Entrega rápida</h3>
          <p class="feature-card__desc">
            Plan básico listo en 1 a 2 días hábiles. Sin esperas largas ni
            promesas vacías.
          </p>
        </article>

        <article class="feature-card fade-up" style="--delay:1">
          <div class="feature-card__icon" aria-hidden="true">📱</div>
          <h3 class="feature-card__title">Diseño para celular</h3>
          <p class="feature-card__desc">
            Más del 80% te busca desde el celular. Nos aseguramos de que se vea
            perfecto.
          </p>
        </article>

        <article class="feature-card fade-up" style="--delay:2">
          <div class="feature-card__icon" aria-hidden="true">🔍</div>
          <h3 class="feature-card__title">Aparecés en Google</h3>
          <p class="feature-card__desc">
            Cada página sale lista con SEO para que Google la encuentre desde el
            primer día.
          </p>
        </article>

        <article class="feature-card fade-up" style="--delay:3">
          <div class="feature-card__icon" aria-hidden="true">💬</div>
          <h3 class="feature-card__title">Atención real</h3>
          <p class="feature-card__desc">
            Respondemos por WhatsApp. No sos un número, sos un cliente con
            nombre y negocio.
          </p>
        </article>
      </div>
    </div>
  </section>

  <Rubros />

  <section
    class="section section--white"
    id="como-funciona"
    aria-labelledby="h2-como"
  >
    <div class="container">
      <h2 class="section__title fade-up" id="h2-como">¿Cómo funciona?</h2>
      <p class="section__subtitle fade-up">
        Tres pasos simples y tu negocio ya está en internet.
      </p>

      <div class="steps">
        <article class="step fade-up" style="--delay:0">
          <div class="step__number" aria-hidden="true">1</div>
          <div class="step__icon" aria-hidden="true">📋</div>
          <h3 class="step__title">Completás el formulario</h3>
          <p class="step__desc">
            Te mandamos el link. Llena los datos de tu negocio en 5 minutos
            desde el celular.
          </p>
          <div class="step__connector" aria-hidden="true"></div>
        </article>

        <article class="step fade-up" style="--delay:1">
          <div class="step__number" aria-hidden="true">2</div>
          <div class="step__icon" aria-hidden="true">⚙️</div>
          <h3 class="step__title">Nosotros armamos todo</h3>
          <p class="step__desc">
            Diseñamos tu página con tus colores, fotos y servicios. Vos no tenés
            que hacer nada técnico.
          </p>
          <div class="step__connector" aria-hidden="true"></div>
        </article>

        <article class="step fade-up" style="--delay:2">
          <div class="step__number" aria-hidden="true">3</div>
          <div class="step__icon" aria-hidden="true">🚀</div>
          <h3 class="step__title">Tu negocio en internet</h3>
          <p class="step__desc">
            Publicamos la página y te mandamos el link listo para compartir con
            tus clientes.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section
    class="section section--gray"
    id="incluye"
    aria-labelledby="h2-incluye"
  >
    <div class="container">
      <h2 class="section__title fade-up" id="h2-incluye">
        ¿Qué incluye siempre tu página?
      </h2>
      <p class="section__subtitle fade-up">
        Independiente del plan que elijas, esto siempre viene incluido.
      </p>

      <div class="includes-grid">
        <article class="include-card fade-up" style="--delay:0">
          <span class="include-card__icon" aria-hidden="true">🎨</span>
          <h3 class="include-card__title">Diseño personalizado</h3>
          <p class="include-card__desc">
            Con los colores y logo de tu negocio.
          </p>
        </article>

        <article class="include-card fade-up" style="--delay:1">
          <span class="include-card__icon" aria-hidden="true">🔍</span>
          <h3 class="include-card__title">SEO básico incluido</h3>
          <p class="include-card__desc">
            Google puede encontrarte desde el día uno.
          </p>
        </article>

        <article class="include-card fade-up" style="--delay:2">
          <span class="include-card__icon" aria-hidden="true">💬</span>
          <h3 class="include-card__title">Botón WhatsApp animado</h3>
          <p class="include-card__desc">
            Tus clientes te contactan con un toque.
          </p>
        </article>

        <article class="include-card fade-up" style="--delay:3">
          <span class="include-card__icon" aria-hidden="true">📱</span>
          <h3 class="include-card__title">100% adaptado a celular</h3>
          <p class="include-card__desc">
            Se ve perfecto en celular, tablet y desktop.
          </p>
        </article>

        <article class="include-card fade-up" style="--delay:4">
          <span class="include-card__icon" aria-hidden="true">📍</span>
          <h3 class="include-card__title">Mapa de Google</h3>
          <p class="include-card__desc">
            Tus clientes te encuentran fácilmente.
          </p>
        </article>

        <article class="include-card fade-up" style="--delay:5">
          <span class="include-card__icon" aria-hidden="true">🔄</span>
          <h3 class="include-card__title">1 cambio al mes</h3>
          <p class="include-card__desc">
            Para mantener tu página siempre actualizada.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section
    class="section section--dark"
    id="precios"
    aria-labelledby="h2-precios"
  >
    <div class="container">
      <h2 class="section__title section__title--light fade-up" id="h2-precios">
        Planes y precios
      </h2>
      <p class="section__subtitle section__subtitle--light fade-up">
        Elegí el plan ideal para tu negocio en Paraguay.
      </p>

      <div class="plans-grid">
        <article class="plan-card fade-up" style="--delay:0">
          <div class="plan-card__header">
            <h3 class="plan-card__name">Plan Básico</h3>
            <div class="plan-card__price">
              <span class="plan-card__currency">Gs.</span>
              <span class="plan-card__amount">{basicPlanAmount}</span>
            </div>
            <p class="plan-card__ideal">
              Ideal para: Veterinarias, salones de belleza, nail spa,
              peluquerías, cerrajerías, escuelas de manejo
            </p>
          </div>
          <ul class="plan-card__features" role="list">
            <li>✅ 1 página completa (landing page)</li>
            <li>✅ Se ve bien en celular</li>
            <li>✅ Botón WhatsApp animado</li>
            <li>✅ SEO básico — aparecés en Google</li>
            <li>✅ Dominio .com incluido 1 año</li>
            <li>✅ Hosting 12 meses</li>
            <li>✅ Mapa de ubicación</li>
            <li>✅ 1 cambio de contenido/mes</li>
            <li>✅ Atención por WhatsApp</li>
          </ul>
          <div class="plan-card__footer">
            <div class="plan-card__delivery">
              ⏱ Entrega: <strong>1-2 días hábiles</strong>
            </div>
            <a
              href={getWhatsAppUrl(
                "Hola Mbarete Digital! Quiero consultar sobre el Plan Básico para mi negocio 👋",
              )}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn--primary btn--full"
              data-plan="Básico"
              aria-label={`Contactar por WhatsApp para contratar Plan Básico por ${planBasico.price}`}
              ><span aria-hidden="true">💬</span> Quiero este plan</a
            >
          </div>
        </article>

        <article
          class="plan-card plan-card--featured fade-up"
          style="--delay:1"
        >
          <div class="plan-card__badge">Más elegido</div>
          <div class="plan-card__header">
            <h3 class="plan-card__name">Plan Estándar</h3>
            <div class="plan-card__price">
              <span class="plan-card__currency">Gs.</span>
              <span class="plan-card__amount">{standardPlanAmount}</span>
            </div>
            <p class="plan-card__ideal">
              Ideal para: Restaurantes, farmacias, gimnasios, estudios
              contables, hoteles, carnicerías
            </p>
          </div>
          <ul class="plan-card__features" role="list">
            <li>✅ Todo lo del plan Básico</li>
            <li>✅ Hasta 4 secciones organizadas</li>
            <li>✅ Diseño a medida completo</li>
            <li>✅ SEO avanzado</li>
            <li>✅ Tu negocio en Google Maps</li>
            <li>✅ Formulario de contacto al email</li>
            <li>✅ Menú de navegación</li>
            <li>✅ 3 cambios de contenido/mes</li>
          </ul>
          <div class="plan-card__footer">
            <div class="plan-card__delivery">
              ⏱ Entrega: <strong>4-8 días hábiles</strong>
            </div>
            <a
              href={getWhatsAppUrl(
                "Hola Mbarete Digital! Quiero consultar sobre el Plan Estándar para mi negocio 👋",
              )}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn--primary btn--full"
              data-plan="Estándar"
              aria-label={`Contactar por WhatsApp para contratar Plan Estándar por ${planEstandar.price}`}
              ><span aria-hidden="true">💬</span> Quiero este plan</a
            >
          </div>
        </article>

        <article class="plan-card fade-up" style="--delay:2">
          <div class="plan-card__header">
            <h3 class="plan-card__name">Plan Pro</h3>
            <div class="plan-card__price">
              <span class="plan-card__currency">Gs.</span>
              <span class="plan-card__amount">{proPlanAmount}</span>
            </div>
            <p class="plan-card__ideal">
              Ideal para: Consultorios, odontologías, inmobiliarias, empresas de
              tecnología, hoteles con reservas
            </p>
          </div>
          <ul class="plan-card__features" role="list">
            <li>✅ Todo lo del plan Estándar</li>
            <li>✅ Páginas internas por servicio</li>
            <li>✅ Blog o sección de noticias</li>
            <li>✅ Galería avanzada con categorías</li>
            <li>✅ Formulario completo personalizado</li>
            <li>✅ Cambios ilimitados por 12 meses</li>
            <li>✅ Hosting premium de mayor velocidad</li>
            <li>✅ Configuración completa Google</li>
            <li>✅ Atención prioritaria por WhatsApp</li>
            <li>✅ Se puede pagar en 2 cuotas</li>
          </ul>
          <div class="plan-card__footer">
            <div class="plan-card__delivery">
              ⏱ Entrega: <strong>7-15 días hábiles</strong>
            </div>
            <a
              href={getWhatsAppUrl(
                "Hola Mbarete Digital! Quiero consultar sobre el Plan Pro para mi negocio 👋",
              )}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn--primary btn--full"
              data-plan="Pro"
              aria-label={`Contactar por WhatsApp para contratar Plan Pro por ${planPro.price}`}
              ><span aria-hidden="true">💬</span> Quiero este plan</a
            >
          </div>
        </article>
      </div>

      <Serviadicional />
    </div>
  </section>
  <Testimonials />

  <section
    class="section section--muestras"
    id="muestras"
    aria-labelledby="h2-muestras"
  >
    <div class="container">
      <div class="muestras-cta fade-up">
        <div class="muestras-cta__text">
          <div class="muestras-cta__badge">🎨 Galería de ejemplos</div>
          <h2 class="muestras-cta__title" id="h2-muestras">
            ¿Querés ver cómo queda antes de decidir?
          </h2>
          <p class="muestras-cta__desc">
            Tenemos páginas de muestra reales para más de 40 rubros.
            Veterinarias, restaurantes, talleres, salones de belleza y mucho
            más. Hacé clic y mirá cómo quedará la tuya.
          </p>
          <div class="muestras-cta__stats">
            <span class="muestras-cta__stat"><strong>40+</strong> ejemplos</span
            >
            <span class="muestras-cta__stat"
              ><strong>100%</strong> funcionales</span
            >
            <span class="muestras-cta__stat"><strong>Mobile</strong> ready</span
            >
          </div>
          <a
            href="/muestras/"
            class="btn btn--primary btn--lg muestras-cta__btn"
          >
            🎨 Ver páginas de muestra
          </a>
        </div>

        <div class="muestras-cta__preview" aria-hidden="true">
          <div class="muestras-cta__screen muestras-cta__screen--1">
            🐾 Veterinaria
          </div>
          <div class="muestras-cta__screen muestras-cta__screen--2">
            🍽️ Restaurante
          </div>
          <div class="muestras-cta__screen muestras-cta__screen--3">
            💇 Salón de belleza
          </div>
          <div class="muestras-cta__screen muestras-cta__screen--4">
            🔧 Taller mecánico
          </div>
          <div class="muestras-cta__screen muestras-cta__screen--5">
            🦷 Odontología
          </div>
          <div class="muestras-cta__screen muestras-cta__screen--6">
            💪 Gimnasio
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--white" id="faq" aria-labelledby="h2-faq">
    <div class="container container--narrow">
      <h2 class="section__title fade-up" id="h2-faq">Preguntas frecuentes</h2>

      <div class="faq-list fade-up" role="list">
        <div class="faq-item" role="listitem">
          <button
            class="faq-item__question"
            aria-expanded="false"
            aria-controls="faq-1"
          >
            ¿Cuánto tarda en estar lista mi página?
            <span class="faq-item__chevron" aria-hidden="true">▼</span>
          </button>
          <div class="faq-item__answer" id="faq-1" role="region">
            <p>
              El Plan Básico se entrega en 1 a 2 días hábiles desde que
              recibimos tus datos y el pago. El Plan Estándar tarda 4 a 8 días y
              el Pro de 7 a 15 días. Son plazos reales, no promesas vacías.
            </p>
          </div>
        </div>

        <div class="faq-item" role="listitem">
          <button
            class="faq-item__question"
            aria-expanded="false"
            aria-controls="faq-2"
          >
            ¿Necesito saber algo de tecnología?
            <span class="faq-item__chevron" aria-hidden="true">▼</span>
          </button>
          <div class="faq-item__answer" id="faq-2" role="region">
            <p>
              No necesitás saber nada. Vos nos mandás el nombre de tu negocio,
              los servicios que ofrecés, tu número de WhatsApp y algunas fotos.
              Nosotros hacemos todo lo demás. Si no tenés fotos, usamos imágenes
              profesionales gratis.
            </p>
          </div>
        </div>

        <div class="faq-item" role="listitem">
          <button
            class="faq-item__question"
            aria-expanded="false"
            aria-controls="faq-3"
          >
            ¿Qué pasa si después quiero cambiar algo en la página?
            <span class="faq-item__chevron" aria-hidden="true">▼</span>
          </button>
          <div class="faq-item__answer" id="faq-3" role="region">
            <p>
              Todos los planes incluyen cambios por mes: 1 en Básico, 3 en
              Estándar, ilimitados en Pro. Para cambios urgentes o extras, los
              cotizamos aparte. Siempre podés escribirnos por WhatsApp.
            </p>
          </div>
        </div>

        <div class="faq-item" role="listitem">
          <button
            class="faq-item__question"
            aria-expanded="false"
            aria-controls="faq-4"
          >
            ¿La página va a aparecer en Google?
            <span class="faq-item__chevron" aria-hidden="true">▼</span>
          </button>
          <div class="faq-item__answer" id="faq-4" role="region">
            <p>
              Sí. Cada página que entregamos viene con SEO básico configurado
              para que Google la encuentre. Si querés aparecer en los primeros
              resultados cuando alguien busca tu rubro en tu ciudad, tenemos el
              servicio de SEO local por {seoLocalPrice} que trabaja eso específicamente.
            </p>
          </div>
        </div>

        <div class="faq-item" role="listitem">
          <button
            class="faq-item__question"
            aria-expanded="false"
            aria-controls="faq-5"
          >
            ¿Qué necesito para empezar?
            <span class="faq-item__chevron" aria-hidden="true">▼</span>
          </button>
          <div class="faq-item__answer" id="faq-5" role="region">
            <p>
              Solo tres cosas: el nombre y datos de tu negocio, tu número de
              WhatsApp y el pago del plan elegido. Con eso ya arrancamos. El
              formulario de datos te lo mandamos por WhatsApp y lo completás
              desde el celular en 5 minutos.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--cta" id="contacto" aria-labelledby="h2-cta">
    <div class="container container--narrow cta-content fade-up">
      <h2 class="cta__title" id="h2-cta">
