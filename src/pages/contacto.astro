---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig, getWhatsAppUrl } from "../data/siteConfig";

const seoTitle = "Contacto y Presupuesto | Mbarete Digital";
const seoDescription = "Solicitá un presupuesto para tu sitio web hoy mismo. Respondemos en menos de 2 horas. WhatsApp y formulario de contacto disponible.";
---

<BaseLayout title={seoTitle} description={seoDescription} canonical={`${siteConfig.url}/contacto/`}>
  <section class="contact-hero section--dark">
    <div class="container container--narrow text-center fade-up">
      <span class="badge badge--py">Atención inmediata</span>
      <h1>Estás a un paso de transformar tu negocio</h1>
      <p>Completá el formulario o escribinos por WhatsApp. Te asesoramos sin cargo sobre la mejor solución para tu rubro.</p>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-form-container fade-up">
          <form id="contact-form" class="modern-form">
            <div class="form-group">
              <label for="name">Nombre / Negocio</label>
              <input type="text" id="name" name="name" placeholder="Ej: Juan Pérez / Veterinaria San Blas" required />
            </div>
            <div class="form-group">
              <label for="rubro">Tu Rubro</label>
              <select id="rubro" name="rubro">
                <option value="web-basica">Página Web Básica</option>
                <option value="web-pro">Sitio Corporativo / Pro</option>
                <option value="seo">SEO Local / Google Maps</option>
                <option value="otro">Otro / Consulta general</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Mensaje (Opcional)</label>
              <textarea id="message" name="message" rows="4" placeholder="Contanos brevemente qué necesitás..."></textarea>
            </div>
            <button type="submit" class="btn btn--primary btn--full btn--lg">Enviar Consulta</button>
            <p class="form-note">Al enviar, te redirigiremos para confirmar tus datos.</p>
          </form>
        </div>

        <div class="contact-info-container fade-up" style="--delay:2">
          <div class="trust-card">
            <h3>Atención ⚡ Mbarete</h3>
            <ul class="trust-list">
              <li>
                <strong>Tiempos:</strong> 
                <span>Respondemos en <span class="highlight">menos de 2 horas</span> durante horario comercial.</span>
              </li>
              <li>
                <strong>WhatsApp:</strong>
                <a href={getWhatsAppUrl("Hola! Vengo desde el formulario de contacto y quiero un presupuesto")} class="wa-direct">
                  {siteConfig.phone} (Clic para chatear)
                </a>
              </li>
              <li>
                <strong>Email:</strong>
                <span>{siteConfig.email}</span>
              </li>
              <li>
                <strong>Ubicación:</strong>
                <span>{siteConfig.address.city}, Paraguay (Atención remota a todo el país).</span>
              </li>
            </ul>
          </div>

          <div class="whatsapp-cta-card">
             <p>¿Preferís saltear el formulario?</p>
             <a href={getWhatsAppUrl("Hola Mbarete Digital! Quiero un presupuesto rápido por aquí 👋")} class="btn btn--white btn--full">
               Hablar directamente por WhatsApp
             </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Simple listener to handle form redirection to WhatsApp or success message
  const form = document.getElementById('contact-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const name = formData.get('name');
      const rubro = formData.get('rubro');
      const message = formData.get('message');
      
      const text = `Hola Mbarete Digital! Soy ${name}. Me interesa el servicio de ${rubro}. ${message ? `Mensaje: ${message}` : ''}`;
      const waUrl = `https://wa.me/595981441200?text=${encodeURIComponent(text)}`;
      
      window.location.href = waUrl;
    });
  }
</script>

<style>
  .contact-hero { padding: 9rem 0 4rem; }
  .contact-hero h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; margin: 1rem 0; color: var(--blanco); }
  .contact-hero p { font-size: 1.15rem; color: var(--texto-light); }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 992px) {
    .contact-grid { grid-template-columns: 1.2fr 0.8fr; }
  }

  .modern-form {
    background: var(--blanco);
    padding: 2.5rem;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    display: grid;
    gap: 1.5rem;
  }

  .form-group {
    display: grid;
    gap: 0.5rem;
  }
  .form-group label {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--azul-oscuro);
  }
  .form-group input, .form-group select, .form-group textarea {
    padding: 12px 16px;
    border: 1.5px solid var(--gris-medio);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: 1rem;
    transition: border-color var(--transition);
  }
  .form-group input:focus {
    outline: none;
    border-color: var(--verde);
  }

  .form-note {
    font-size: 0.8rem;
    color: var(--texto-muted);
    text-align: center;
  }

  .trust-card {
    background: var(--azul-oscuro);
    color: var(--blanco);
    padding: 2.5rem;
    border-radius: var(--radius-xl);
    margin-bottom: 2rem;
  }
  .trust-card h3 { margin-bottom: 1.5rem; color: var(--verde-claro); }
  .trust-list { display: grid; gap: 1.5rem; }
  .trust-list li { display: grid; gap: 0.25rem; }
  .trust-list strong { font-size: 0.8rem; text-transform: uppercase; color: rgba(255,255,255,0.5); }
  .highlight { color: var(--verde-claro); font-weight: 700; }
  .wa-direct { font-weight: 700; color: var(--verde-claro); text-decoration: underline; }

  .whatsapp-cta-card {
    background: var(--verde);
    padding: 2rem;
    border-radius: var(--radius-xl);
    color: var(--blanco);
    text-align: center;
  }
  .whatsapp-cta-card p { font-weight: 700; margin-bottom: 1rem; }
</style>
