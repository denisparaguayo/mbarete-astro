---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig, getWhatsAppUrl } from '../data/siteConfig';
import { getServiceBySlugOrThrow } from '../data/services';

const creacionWebService = getServiceBySlugOrThrow('creacion-paginas-web');
const creacionWebPrice = creacionWebService.price;
const creacionWebPriceInline = creacionWebPrice.replace(/^Desde/i, 'desde');
---

<BaseLayout
	title={`Creacion de paginas web en Paraguay | ${creacionWebPrice}`}
	description={`Creacion de paginas web en Paraguay ${creacionWebPriceInline}. Diseno profesional, SEO incluido y entrega en 1-2 dias.`}
	canonical={`${siteConfig.url}/creacion-paginas-web/`}
	navbarSolid={true}>
	<main class="seo-page">
		<div class="container container--narrow">
			<h1>Creacion de paginas web en Paraguay para negocios reales</h1>

			<p>
				Necesitas una <strong>pagina web en Paraguay</strong>? Creamos paginas
				profesionales {creacionWebPriceInline} con SEO incluido.
			</p>

			<h2>Como funciona?</h2>
			<ul>
				<li>Nos mandas los datos</li>
				<li>Disenamos tu pagina</li>
				<li>Te entregamos lista</li>
			</ul>

			<h2>Tipos de paginas</h2>

			<h3>Landing page</h3>
			<p>Ideal para empezar. Entrega en 1-2 dias.</p>

			<h3>Web estandar</h3>
			<p>Mas secciones y mejor SEO.</p>

			<h3>Web completa</h3>
			<p>Incluye blog, galeria y mas.</p>

			<div class="seo-cta">
				<h2>Queres tu pagina web?</h2>
				<p>Escribinos ahora y empezamos hoy</p>

				<a
					href={getWhatsAppUrl()}
					class="btn btn--white btn--lg"
					target="_blank">
					💬 WhatsApp
				</a>
			</div>
		</div>
	</main>
</BaseLayout>
