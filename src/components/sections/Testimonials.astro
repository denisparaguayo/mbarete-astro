---
import testimonios from '../../data/testimonios-google.json';

const starsFromRating = (rating: number) =>
	String.fromCharCode(9733).repeat(Math.max(0, Math.min(5, rating)));

const getInitials = (name: string) => {
	const cleanName = name.replace(/\(.*?\)/g, '').trim();
	const parts = cleanName.split(/\s+/).filter(Boolean).slice(0, 2);
	return parts.map((part) => part[0]?.toUpperCase() ?? '').join('') || 'CL';
};
---

<section
	class="section section--testimonios"
	id="testimonios"
	aria-labelledby="h2-testimonios">
	<div class="container">
		<h2
			class="section__title section__title--light fade-up"
			id="h2-testimonios">
			Lo que dicen nuestros clientes en Google
		</h2>
		<p class="section__subtitle section__subtitle--light fade-up">
			Opiniones verificadas de {testimonios.businessName}.
		</p>

		<div class="testimonios-slider fade-up" data-testimonials-slider>
			<ul class="testimonios-slider__track" role="list" data-testimonials-track>
				{
					testimonios.reviews.map((review, index) => (
						<li class="testimonios-slider__slide">
							<article
								class="testimonio-card fade-up"
								style={`--delay:${index % 6}`}
								data-review-id={review.id}>
								<div class="testimonio-card__head">
									<div
										class="testimonio-card__stars"
										aria-label={`${review.rating} estrellas`}>
										{starsFromRating(review.rating)}
									</div>
									{/* <div class="testimonio-card__meta">
										<span class="testimonio-card__source">
											{testimonios.source}
										</span>
										<span>{review.relativeTime}</span>
										{review.isNew ? (
											<span class="testimonio-card__tag">Nuevo</span>
										) : null}
									</div> */}
								</div>

								{review.comment ? (
									<blockquote class="testimonio-card__quote">
										{review.comment}
									</blockquote>
								) : (
									<p class="testimonio-card__quote testimonio-card__quote--empty">
										Esta opinion no incluye comentario escrito.
									</p>
								)}

								<div class="testimonio-card__author">
									<span class="testimonio-card__avatar" aria-hidden="true">
										{getInitials(review.authorName)}
									</span>
									<div>
										<strong class="testimonio-card__name">
											{review.authorName}
										</strong>
										<span class="testimonio-card__biz">
											{review.authorMeta}
										</span>
									</div>
								</div>

								{/* {review.ownerReply ? (
									<div class="testimonio-card__reply">
										<p class="testimonio-card__reply-head">
											{review.ownerReply.author} •{' '}
											{review.ownerReply.relativeTime}
										</p>
										<p class="testimonio-card__reply-text">
											{review.ownerReply.message}
										</p>
									</div>
								) : null} */}
							</article>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>

<script>
	const sliders = document.querySelectorAll('[data-testimonials-slider]');
	const AUTOPLAY_DELAY_MS = 3000;

	sliders.forEach((slider) => {
		const track = slider.querySelector('[data-testimonials-track]');
		if (!track) return;

		const getStep = () => {
			const firstSlide = track.querySelector('.testimonios-slider__slide');
			const styles = window.getComputedStyle(track);
			const gap = Number.parseFloat(styles.columnGap || styles.gap || '0') || 0;

			if (!firstSlide) return track.clientWidth;
			return Math.ceil(firstSlide.getBoundingClientRect().width + gap);
		};

		let autoplayTimer = null;

		const goNext = () => {
			const maxScrollLeft = track.scrollWidth - track.clientWidth;
			const step = getStep();
			const nextLeft = track.scrollLeft + step;

			if (nextLeft >= maxScrollLeft - 8) {
				track.scrollTo({ left: 0, behavior: 'smooth' });
				return;
			}

			track.scrollTo({ left: nextLeft, behavior: 'smooth' });
		};

		const stopAutoplay = () => {
			if (!autoplayTimer) return;
			window.clearInterval(autoplayTimer);
			autoplayTimer = null;
		};

		const startAutoplay = () => {
			if (autoplayTimer) return;
			autoplayTimer = window.setInterval(goNext, AUTOPLAY_DELAY_MS);
		};

		const handleViewportVisibility = (isVisible) => {
			if (isVisible) {
				startAutoplay();
				return;
			}
			stopAutoplay();
		};

		window.addEventListener('resize', () => {
			stopAutoplay();
			startAutoplay();
		});
		slider.addEventListener('mouseenter', stopAutoplay);
		slider.addEventListener('mouseleave', startAutoplay);
		slider.addEventListener('focusin', stopAutoplay);
		slider.addEventListener('focusout', startAutoplay);
		slider.addEventListener('touchstart', stopAutoplay, { passive: true });
		slider.addEventListener('touchend', startAutoplay);

		if ('IntersectionObserver' in window) {
			const observer = new IntersectionObserver(
				(entries) => {
					const entry = entries[0];
					handleViewportVisibility(entry?.isIntersecting ?? true);
				},
				{
					threshold: 0.2,
				}
			);
			observer.observe(slider);
		}

		startAutoplay();
	});
</script>

<style>
	.testimonios-slider {
		position: relative;
	}

	.testimonios-slider__track {
		display: grid;
		grid-auto-flow: column;
		grid-auto-columns: 100%;
		gap: 18px;
		overflow-x: auto;
		scroll-snap-type: x mandatory;
		overscroll-behavior-x: contain;
		scrollbar-width: none;
		-ms-overflow-style: none;
		padding: 6px 2px 12px;
		touch-action: pan-x;
	}

	.testimonios-slider__track::-webkit-scrollbar {
		display: none;
	}

	.testimonios-slider__slide {
		scroll-snap-align: start;
		list-style: none;
	}

	.testimonio-card {
		position: relative;
		background: transparent;
		border: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 14px;
		transition:
			transform var(--transition),
			opacity var(--transition);
	}

	.testimonio-card:hover {
		transform: translateY(-3px);
	}

	.testimonio-card__head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
		padding: 0 6px;
	}

	.testimonio-card__stars {
		font-size: 1rem;
		color: #fbbf24;
		letter-spacing: 1px;
	}

	.testimonio-card__meta {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-size: 0.78rem;
		color: rgba(255, 255, 255, 0.62);
		font-weight: 600;
	}

	.testimonio-card__quote {
		font-size: 1rem;
		color: #1f2937;
		line-height: 1.7;
		font-style: italic;
		font-weight: 500;
		flex: 1;
		background: #f8fafc;
		border-radius: 12px;
		padding: 24px 22px 26px;
		position: relative;
		margin: 0;
		quotes: '\201C' '\201D';
		box-shadow: 0 10px 28px rgba(10, 22, 40, 0.22);
	}

	.testimonio-card__quote--empty {
		color: #475569;
	}

	.testimonio-card__quote::before {
		content: open-quote;
		font-family: var(--font-titulo);
		font-size: 2.2rem;
		color: rgba(10, 22, 40, 0.22);
		position: absolute;
		top: 2px;
		left: 12px;
		line-height: 1;
	}

	.testimonio-card__quote::after {
		content: '';
		position: absolute;
		top: 100%;
		left: 38px;
		width: 0;
		height: 0;
		border-left: 0 solid transparent;
		border-right: 18px solid transparent;
		border-top: 18px solid #f8fafc;
	}

	.testimonio-card__author {
		display: flex;
		align-items: center;
		gap: 12px;
		padding-left: 12px;
	}

	.testimonio-card__avatar {
		font-size: 0.82rem;
		font-weight: 800;
		width: 44px;
		height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: #e2e8f0;
		color: #0f172a;
		border-radius: 50%;
		flex-shrink: 0;
		border: 3px solid rgba(255, 255, 255, 0.18);
	}

	.testimonio-card__name {
		display: block;
		font-weight: 700;
		font-size: 0.95rem;
		color: var(--blanco);
		text-transform: uppercase;
		letter-spacing: 0.03em;
	}

	.testimonio-card__biz {
		display: block;
		font-size: 0.8rem;
		color: rgba(255, 255, 255, 0.5);
		font-weight: 500;
	}

	@media (min-width: 768px) {
		.testimonios-slider__track {
			grid-auto-columns: minmax(320px, 52%);
		}
	}

	@media (min-width: 1024px) {
		.testimonios-slider__track {
			grid-auto-columns: minmax(320px, 34%);
		}
	}
</style>
