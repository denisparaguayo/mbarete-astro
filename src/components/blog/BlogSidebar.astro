---
import { getWhatsAppUrl } from '../../data/siteConfig';

const { posts = [], categories = [] } = Astro.props;
---

<aside class="blog-sidebar">
	<div class="blog-sidebar__box blog-sidebar__box--cta">
		<span class="badge badge--blog">🚀 Mbarete Digital</span>
		<h3>¿Querés una web que te genere clientes?</h3>
		<p>Creamos páginas web rápidas, profesionales y optimizadas para Google.</p>
		<a
			href={getWhatsAppUrl(
				'Hola Mbarete Digital! Vi el blog y quiero una página web para mi negocio 👋'
			)}
			class="btn btn--primary btn--lg"
			target="_blank"
			rel="noopener noreferrer">
			💬 Consultar ahora
		</a>
	</div>

	<div class="blog-sidebar__box">
		<h3 class="blog-sidebar__title">Posts recientes</h3>
		<ul class="blog-sidebar__list">
			{
				posts.slice(0, 5).map((post) => {
					const slug = post.id.replace(/\.(md|mdx)$/, '');
					return (
						<li>
							<a href={`/blog/${slug}/`}>{post.data.title}</a>
						</li>
					);
				})
			}
		</ul>
	</div>

	<div class="blog-sidebar__box">
		<h3 class="blog-sidebar__title">Categorías</h3>
		<div class="blog-sidebar__tags">
			{
				categories.map((category) => (
					<a
						href={`/blog/categoria/${category.slug}/`}
						class="blog-sidebar__tag">
						{category.name}
					</a>
				))
			}
		</div>
	</div>
</aside>

<style>
	.blog-sidebar {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		height: fit-content;
	}

	.blog-sidebar__box {
		background: rgba(255, 255, 255, 0.5);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		border-radius: var(--radius-xl);
		padding: 1.5rem;
		box-shadow: 0 14px 40px rgba(10, 22, 40, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.6);
		transition: transform 0.3s ease;
	}

	.blog-sidebar__box--cta {
		background: linear-gradient(135deg, var(--azul-oscuro) 0%, #1a3a6b 100%);
		color: var(--blanco);
		border: none;
		box-shadow: 0 15px 35px rgba(10, 22, 40, 0.2);
	}

	.blog-sidebar__box--cta h3 {
		font-size: 1.25rem;
		margin: 0.8rem 0 0.6rem;
		line-height: 1.25;
		font-weight: 800;
	}

	.blog-sidebar__box--cta p {
		font-size: 0.95rem;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.85);
		margin-bottom: 1.25rem;
	}

	.blog-sidebar__title {
		font-family: var(--font-titulo);
		font-size: 0.92rem;
		font-weight: 850;
		color: var(--azul-oscuro);
		margin-bottom: 1.25rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		display: flex;
		align-items: center;
		gap: 10px;
	}

	.blog-sidebar__title::after {
		content: '';
		flex: 1;
		height: 2px;
		background: linear-gradient(to right, rgba(5, 150, 105, 0.3), transparent);
		border-radius: 2px;
	}

	.blog-sidebar__list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.blog-sidebar__list a {
		text-decoration: none;
		color: var(--texto);
		font-size: 0.92rem;
		font-weight: 600;
		line-height: 1.4;
		transition: all var(--transition);
		display: block;
	}

	.blog-sidebar__list a:hover {
		color: var(--verde);
		transform: translateX(4px);
	}

	.blog-sidebar__tags {
		display: flex;
		flex-wrap: wrap;
		font-weight: 700;
		color: var(--texto-muted);
		background: rgba(10, 22, 40, 0.04);
		padding: 6px 12px;
		border-radius: var(--radius-pill);
		transition: all var(--transition);
		border-color: var(--verde);
		transform: translateY(-1px);
	}

	@media (min-width: 1024px) {
		.blog-sidebar {
			position: sticky;
			top: 100px;
		}
	}
</style>
