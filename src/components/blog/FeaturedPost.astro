---
const { post } = Astro.props;

if (!post) {
	throw new Error('FeaturedPost necesita un post');
}

const slug = post.id.replace(/\.(md|mdx)$/, '');
---

<article class="featured-post">
	<a href={`/blog/${slug}/`} class="featured-post__link">
		{
			post.data.heroImage && (
				<div class="featured-post__image">
					<img
						src={post.data.heroImage}
						alt={post.data.title}
						loading="eager"
					/>
				</div>
			)
		}

		<div class="featured-post__content">
			{
				post.data.category ? (
					<span class="badge badge--blog featured-post__badge">
						{post.data.category}
					</span>
				) : (
					<span class="badge badge--blog featured-post__badge">Destacado</span>
				)
			}

			<h2 class="featured-post__title">{post.data.title}</h2>

			<p class="featured-post__desc">{post.data.description}</p>

			<div class="featured-post__meta">
				<time datetime={post.data.pubDate.toISOString()}>
					📅 {post.data.pubDate.toLocaleDateString('es-PY')}
				</time>

				<span class="featured-post__cta">Leer artículo →</span>
			</div>
		</div>
	</a>
</article>

<style>
	.featured-post {
		background: rgba(255, 255, 255, 0.7);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-radius: var(--radius-2xl);
		overflow: hidden;
		box-shadow: 0 20px 50px rgba(10, 22, 40, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.5);
		transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
		margin-bottom: 3rem;
	}

	.featured-post:hover {
		transform: translateY(-10px);
		box-shadow: 0 30px 60px rgba(5, 150, 105, 0.15);
		border-color: rgba(5, 150, 105, 0.25);
	}

	.featured-post__link {
		text-decoration: none;
		display: grid;
		grid-template-columns: 1fr;
		height: 100%;
	}

	.featured-post__image {
		height: 300px;
		overflow: hidden;
		position: relative;
	}

	.featured-post__image::after {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(to bottom, transparent 0%, rgba(10, 22, 40, 0.2) 100%);
	}

	.featured-post__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
	}

	.featured-post:hover .featured-post__image img {
		transform: scale(1.06);
	}

	.featured-post__content {
		padding: 2.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		background: rgba(255, 255, 255, 0.1);
	}

	.featured-post__badge {
		width: fit-content;
		font-weight: 850;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		font-size: 0.75rem;
		background: rgba(5, 150, 105, 0.12) !important;
		color: var(--verde) !important;
		border: 1px solid rgba(5, 150, 105, 0.2) !important;
		display: flex;
		align-items: center;
		gap: 6px;
	}

	.featured-post__title {
		font-size: clamp(1.8rem, 4vw, 2.8rem);
		line-height: 1.1;
		margin: 0;
		color: var(--azul-oscuro);
		font-weight: 900;
		letter-spacing: -0.03em;
	}

	.featured-post__desc {
		font-size: 1.1rem;
		line-height: 1.8;
		color: var(--texto-muted);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.featured-post__meta {
		margin-top: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-size: 0.9rem;
		color: var(--texto-muted);
		padding-top: 1.5rem;
		border-top: 1px solid rgba(10, 22, 40, 0.06);
	}

	.featured-post__cta {
		font-weight: 900;
		color: var(--verde);
		display: flex;
		align-items: center;
		gap: 6px;
		transition: gap 0.3s ease;
	}

	.featured-post:hover .featured-post__cta {
		gap: 10px;
	}

	@media (min-width: 900px) {
		.featured-post__link {
			grid-template-columns: 1.1fr 1fr;
		}

		.featured-post__image {
			height: 100%;
			min-height: 400px;
		}

		.featured-post__content {
			padding: 3.5rem;
		}
	}
</style>
