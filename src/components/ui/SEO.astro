---
import { siteConfig } from '../../data/siteConfig';
import { getServicePlanBySlugOrThrow } from '../../data/services';

interface Props {
	schema?: object | object[];
	breadcrumbs?: { name: string; url: string }[];
}

const { schema, breadcrumbs } = Astro.props;

// Generar esquema de BreadcrumbList si hay datos
const breadcrumbSchema = breadcrumbs
	? {
			'@context': 'https://schema.org',
			'@type': 'BreadcrumbList',
			itemListElement: breadcrumbs.map((crumb, index) => ({
				'@type': 'ListItem',
				position: index + 1,
				name: crumb.name,
				item: new URL(crumb.url, siteConfig.url).toString(),
			})),
		}
	: null;

const isHomePage = Astro.url.pathname === '/' || Astro.url.pathname === '';

const planBasico = getServicePlanBySlugOrThrow('basico');
const planPro = getServicePlanBySlugOrThrow('pro');

const cleanPrice = (price: string) => price.replace(/[^\d]/g, '');
const priceBasico = cleanPrice(planBasico.price);
const pricePro = cleanPrice(planPro.price);

const professionalServiceSchema = {
	'@context': 'https://schema.org',
	'@type': 'ProfessionalService',
	name: siteConfig.name,
	url: siteConfig.url,
	logo: new URL('/favicon.svg', siteConfig.url).toString(),
	image: siteConfig.seo.ogImage,
	description:
		'Plataforma de desarrollo de software e infraestructura digital en Paraguay. Especialistas en creación de sitios web, SEO local y soluciones tecnológicas profesionales.',
	serviceType: [
		'Software Development',
		'Web Design',
		'Local SEO',
		'Digital Infrastructure',
	],
	telephone: `+${siteConfig.whatsapp}`,
	email: siteConfig.email,
	priceRange: `PYG ${priceBasico} - ${pricePro}`,
	address: {
		'@type': 'PostalAddress',
		addressLocality: siteConfig.address.city,
		addressCountry: 'PY',
	},
	geo: {
		'@type': 'GeoCoordinates',
		latitude: -25.2867, // Asunción
		longitude: -57.647,
	},
	areaServed: {
		'@type': 'Country',
		name: 'Paraguay',
	},
	openingHoursSpecification: {
		'@type': 'OpeningHoursSpecification',
		dayOfWeek: [
			'Monday',
			'Tuesday',
			'Wednesday',
			'Thursday',
			'Friday',
			'Saturday',
		],
		opens: '08:00',
		closes: '18:00',
	},
	sameAs: [siteConfig.socials?.instagram, siteConfig.socials?.facebook].filter(
		Boolean
	),
};

const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: siteConfig.name,
	url: siteConfig.url,
	logo: new URL('/favicon.svg', siteConfig.url).toString(),
	description:
		'Agencia paraguaya de soluciones web y desarrollo de software. Líder en infraestructura digital rápida para PYMES y empresas.',
	contactPoint: {
		'@type': 'ContactPoint',
		telephone: `+${siteConfig.whatsapp}`,
		contactType: 'customer service',
		areaServed: 'PY',
		availableLanguage: 'Spanish',
	},
	sameAs: [siteConfig.socials?.instagram, siteConfig.socials?.facebook].filter(
		Boolean
	),
};

const webSiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: siteConfig.name,
	url: siteConfig.url,
	potentialAction: {
		'@type': 'SearchAction',
		target: `${siteConfig.url}/?q={search_term_string}`,
		'query-input': 'required name=search_term_string',
	},
};

const mainNavigationLinks = [
	{ name: 'Inicio', path: '/' },
	{ name: 'Servicios', path: '/servicios/' },
	{ name: 'Muestras', path: '/muestras/' },
	{ name: 'Blog', path: '/blog/' },
	{ name: 'Preguntas Frecuentes', path: '/faq/' },
];

const siteNavigationSchema = {
	'@context': 'https://schema.org',
	'@type': 'SiteNavigationElement',
	name: mainNavigationLinks.map((link) => link.name),
	url: mainNavigationLinks.map((link) =>
		new URL(link.path, siteConfig.url).toString()
	),
};

// Construir lista de esquemas dinámicamente
const baseSchemas = [professionalServiceSchema, siteNavigationSchema];

if (isHomePage) {
	baseSchemas.push(organizationSchema);
	baseSchemas.push(webSiteSchema);
}

if (breadcrumbSchema) {
	baseSchemas.push(breadcrumbSchema);
}

const schemas = schema
	? Array.isArray(schema)
		? [...baseSchemas, ...schema]
		: [...baseSchemas, schema]
	: baseSchemas;
---

{
	schemas.map((item) => (
		<script type="application/ld+json" set:html={JSON.stringify(item)} />
	))
}
