---
import { siteConfig } from '../data/siteConfig';
import { getServicePlanBySlugOrThrow } from '../data/services';

interface Props {
	schema?: object | object[];
}

const { schema } = Astro.props;

const planBasico = getServicePlanBySlugOrThrow('basico');
const planPro = getServicePlanBySlugOrThrow('pro');

const professionalServiceSchema = {
	'@context': 'https://schema.org',
	'@type': 'ProfessionalService',
	name: siteConfig.name,
	url: siteConfig.url,
	description: siteConfig.seo.defaultDescription,
	telephone: `+${siteConfig.whatsapp}`,
	email: siteConfig.email,
	priceRange: `${planBasico.price} - ${planPro.price}`,
	address: {
		'@type': 'PostalAddress',
		addressLocality: siteConfig.address.city,
		addressCountry: 'PY',
	},
	areaServed: {
		'@type': 'Country',
		name: 'Paraguay',
	},
	openingHoursSpecification: {
		'@type': 'OpeningHoursSpecification',
		dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
		opens: '08:00',
		closes: '18:00',
	},
	sameAs: [siteConfig.socials?.instagram, siteConfig.socials?.facebook].filter(
		Boolean
	),
};

const mainNavigationLinks = [
	{ name: 'Inicio', path: '/' },
	{ name: 'Servicios', path: '/servicios/' },
	{ name: 'Muestras', path: '/muestras/' },
	{ name: 'Blog', path: '/blog/' },
	{ name: 'Preguntas Frecuentes', path: '/faq/' },
];

const siteNavigationSchema = {
	'@context': 'https://schema.org',
	'@type': 'SiteNavigationElement',
	name: mainNavigationLinks.map((link) => link.name),
	url: mainNavigationLinks.map((link) =>
		new URL(link.path, siteConfig.url).toString()
	),
};

const schemas = schema
	? Array.isArray(schema)
		? [professionalServiceSchema, siteNavigationSchema, ...schema]
		: [professionalServiceSchema, siteNavigationSchema, schema]
	: [professionalServiceSchema, siteNavigationSchema];
---

{
	schemas.map((item) => (
		<script type="application/ld+json" set:html={JSON.stringify(item)} />
	))
}
